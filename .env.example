# Qwen text model (required for live parsing and creative briefs)
QWEN_API_KEY=
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen3.7-plus
QWEN_AGENT_MODEL=qwen3.7-plus
QWEN_AGENT_API_KEY=
QWEN_AGENT_BASE_URL=
QWEN_MARKETING_MODEL=qwen3.7-plus
QWEN_VISION_MODEL=qwen3.7-plus
QWEN_ASR_API_KEY=
QWEN_ASR_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_ASR_MODEL=qwen3-asr-flash
QWEN_VOICE_DESIGN_MODEL=qwen-voice-design
QWEN_VOICE_DESIGN_TARGET_MODEL=qwen3-tts-vd-2026-01-26
QWEN_VOICE_DESIGN_ENDPOINT=
QWEN_TTS_MODEL=qwen3-tts-vd-2026-01-26
QWEN_TTS_VOICE=
QWEN_TTS_ENDPOINT=
QWEN_VIDEO_MODEL=happyhorse-1.0-i2v
QWEN_VIDEO_ENDPOINT=
QWEN_VIDEO_TASK_BASE_URL=
QWEN_VIDEO_TIMEOUT_MS=240000

# Qwen-Image Edit can use a separate regional workspace key.
QWEN_IMAGE_API_KEY=
QWEN_IMAGE_MODEL=wan2.7-image-pro
QWEN_IMAGE_FALLBACK_MODEL=qwen-image-2.0-pro

# Optional workspace-specific endpoints
QWEN_BASE_URL=
QWEN_IMAGE_BASE_URL=
QWEN_TTS_BASE_URL=
QWEN_VIDEO_BASE_URL=
QWEN_WORKSPACE_ID=
QWEN_REGION=ap-northeast-1

# Runtime defaults for Alibaba Cloud Function Compute custom containers
HOST=0.0.0.0
PORT=9000
QWEN_TIMEOUT_MS=45000
# Generated by npm run deploy:prepare. Share only the final ?access= URL.
QUOTEX_ACCESS_TOKEN=
# Exact browser origins allowed to call the Function Compute API.
QUOTEX_CORS_ORIGINS=https://mongonsh.github.io
# Optional browser UI. Cloud deployment redirects HTML navigation here.
QUOTEX_PUBLIC_APP_URL=

# Local persistence fallback
QUOTEX_STORAGE_PROVIDER=sqlite
QUOTEX_DB_PATH=.runtime/quotex.sqlite

# Alibaba Cloud managed persistence (recommended for Function Compute)
# Tablestore keeps listing metadata and inspectable agent-run evidence.
TABLESTORE_REGION=ap-northeast-1
TABLESTORE_INSTANCE_NAME=
TABLESTORE_ENDPOINT=
TABLESTORE_LISTINGS_TABLE=quotex_listings
TABLESTORE_AGENT_RUNS_TABLE=quotex_agent_runs
TABLESTORE_AUTO_CREATE_TABLES=false

# OSS keeps private source photos; the API streams them after authorization.
OSS_REGION=oss-ap-northeast-1
OSS_BUCKET=
OSS_INTERNAL=true
OSS_OBJECT_PREFIX=quotex
OSS_SERVER_SIDE_ENCRYPTION=AES256

# Local provisioning credentials only. Function Compute receives short-lived
# credentials from ALIBABA_FC_ROLE_ARN; never bake these values into an image.
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIBABA_CLOUD_SECURITY_TOKEN=

# Alibaba Container Registry Personal Edition repository in the same account
# and region as Function Compute. Obtain these from the ACR push instructions.
ALIBABA_ACR_REGISTRY=
ALIBABA_ACR_NAMESPACE=quotex
ALIBABA_ACR_REPOSITORY=agent
ALIBABA_ACR_USERNAME=
ALIBABA_ACR_PASSWORD=
ALIBABA_ACR_TAG=
CONTAINER_ENGINE=/opt/podman/bin/podman

# Alibaba Cloud FC3 deployment (used by npm run deploy:plan / deploy:fc)
# Use "code" for the ACR-free ZIP path. Code mode requires
# QUOTEX_STORAGE_PROVIDER=memory or alibaba; memory is demo-only and ephemeral.
ALIBABA_FC_DEPLOYMENT_MODE=container
ALIBABA_FC_CODE_ZIP=
ALIBABA_FC_REGION=ap-northeast-1
ALIBABA_FC_ENDPOINT=fcv3.ap-northeast-1.aliyuncs.com
ALIBABA_FC_FUNCTION_NAME=quotex-autopilot
ALIBABA_FC_IMAGE=
ALIBABA_FC_CPU=0.5
ALIBABA_FC_MEMORY_MB=1024
ALIBABA_FC_TIMEOUT_SECONDS=300
ALIBABA_FC_CONCURRENCY=1
ALIBABA_FC_ROLE_ARN=
ALIBABA_FC_DB_PATH=/tmp/quotex.sqlite
ALIBABA_SLS_PROJECT=
ALIBABA_SLS_LOGSTORE=
